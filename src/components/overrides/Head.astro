---
// 覆盖 Starlight 默认 Head 组件，注入可折叠侧边栏 + MathJax 数学公式渲染
const { head } = Astro.locals.starlightRoute;
---

{
  head.map(({ tag: Tag, attrs, content }) => (
    <Tag {...attrs} set:html={content} />
  ))
}
<!-- MathJax 配置：必须在 CDN 脚本加载前执行，is:inline 避免被 Astro 打包/defer -->
<script is:inline>
  window.MathJax = {
    tex: {
      inlineMath: [
        ['$', '$'],
        ['\\(', '\\)'],
      ],
      displayMath: [
        ['$$', '$$'],
        ['\\[', '\\]'],
      ],
    },
    options: {
      // 跳过代码块等标签，避免代码里的 $ 被误处理
      skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code'],
    },
  };
</script>
<script is:inline src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js" defer></script>
<script src="/scripts/collapsible-sidebars.js" defer></script>
