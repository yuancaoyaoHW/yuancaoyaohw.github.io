---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>yuancaoyaohw</title>
    <meta name="description" content="yuancaoyaohw 的电子书与博客入口" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // 防止主题闪烁：在首次绘制前根据存储/系统偏好设置 data-theme
      (function () {
        var stored = localStorage.getItem('theme');
        var theme =
          stored ||
          (window.matchMedia('(prefers-color-scheme: light)').matches
            ? 'light'
            : 'dark');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <style>
      :root {
        --font-display: "Bricolage Grotesque", Arial, sans-serif;
        --font-body: "Inter", system-ui, -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
        --radius: 10px;
      }

      /* —— 深色主题（默认） —— */
      [data-theme="dark"] {
        --black: #080D10;
        --bg-1: #0B1117;
        --bg-2: #0E141C;
        --panel: #131A24;
        --panel-hover: #18212E;
        --white: #FFFFFF;
        --orange: #FF7A00;
        --orange-soft: rgba(255, 122, 0, 0.12);
        --text: #E7ECF3;
        --text-muted: #7C8699;
        --border: #1E2733;
        --border-hover: #2A3744;
        --nav-bg: rgba(8, 13, 16, 0.72);
        --grid-line: rgba(255, 255, 255, 0.025);
        --glow-1: rgba(255, 122, 0, 0.12);
        --glow-2: rgba(255, 122, 0, 0.07);
        --footer-link: #FFFFFF;
      }

      /* —— 浅色主题 —— */
      [data-theme="light"] {
        --black: #FAFAF7;
        --bg-1: #F4F4EF;
        --bg-2: #EFEEE9;
        --panel: #FFFFFF;
        --panel-hover: #F8F8F3;
        --white: #1A1F26;
        --orange: #E8620F;
        --orange-soft: rgba(232, 98, 15, 0.10);
        --text: #2C3338;
        --text-muted: #6A737B;
        --border: #E2E3DD;
        --border-hover: #CFD0C8;
        --nav-bg: rgba(250, 250, 247, 0.74);
        --grid-line: rgba(0, 0, 0, 0.035);
        --glow-1: rgba(232, 98, 15, 0.08);
        --glow-2: rgba(232, 98, 15, 0.05);
        --footer-link: #1A1F26;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      html { scroll-behavior: smooth; }

      body {
        background: var(--black);
        color: var(--text);
        font-family: var(--font-body);
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
        transition: background 0.3s ease, color 0.3s ease;
      }

      a { color: inherit; text-decoration: none; }

      /* —— 全局环境光背景 —— */
      .bg-glow {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
          radial-gradient(50% 40% at 85% 5%, var(--glow-1) 0%, transparent 60%),
          radial-gradient(35% 25% at 20% 35%, var(--glow-2) 0%, transparent 60%);
      }

      .bg-grid {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background-image:
          linear-gradient(var(--grid-line) 1px, transparent 1px),
          linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
        background-size: 56px 56px;
        mask-image: radial-gradient(ellipse 90% 70% at 50% 20%, black 20%, transparent 75%);
        -webkit-mask-image: radial-gradient(ellipse 90% 70% at 50% 20%, black 20%, transparent 75%);
      }

      /* —— Nav —— */
      .nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        background: var(--nav-bg);
        border-bottom: 1px solid var(--border);
        color: var(--white);
        padding: 16px 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: var(--font-display);
      }

      .nav .brand {
        font-size: 17px;
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--white);
      }

      .nav .nav-links {
        display: flex;
        gap: 28px;
        align-items: center;
      }

      .nav .nav-links a {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--text-muted);
        transition: color 0.2s;
      }

      .nav .nav-links a:hover { color: var(--white); }

      .nav .cta {
        border: 1px solid var(--border-hover);
        color: var(--white);
        padding: 8px 20px;
        border-radius: var(--radius);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        background: transparent;
      }

      .nav .cta:hover { border-color: var(--orange); color: var(--orange); }

      /* —— 主题切换按钮 —— */
      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        padding: 0;
        border: 1px solid var(--border-hover);
        border-radius: var(--radius);
        background: transparent;
        color: var(--text-muted);
        cursor: pointer;
        transition: color 0.2s, border-color 0.2s;
        flex-shrink: 0;
      }

      .theme-toggle:hover { color: var(--orange); border-color: var(--orange); }

      .theme-toggle svg { width: 16px; height: 16px; }

      [data-theme="dark"] .theme-toggle .icon-moon { display: none; }
      [data-theme="light"] .theme-toggle .icon-sun { display: none; }

      /* —— 主内容容器 —— */
      .page {
        position: relative;
        z-index: 1;
      }

      /* —— Hero —— */
      .hero {
        padding: 180px 32px 100px;
        position: relative;
      }

      .hero-inner {
        max-width: 1000px;
        margin: 0 auto;
      }

      .hero .eyebrow {
        display: inline-block;
        font-family: var(--font-display);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--orange);
        margin-bottom: 28px;
      }

      .hero h1 {
        font-family: var(--font-display);
        font-size: clamp(36px, 6.5vw, 72px);
        font-weight: 500;
        line-height: 1.1;
        letter-spacing: -0.03em;
        margin-bottom: 32px;
        color: var(--white);
      }

      .hero h1 .accent { color: var(--orange); }

      .hero .lede {
        max-width: 560px;
        font-size: 18px;
        line-height: 1.65;
        color: var(--text-muted);
      }

      /* —— Section 通用 —— */
      .section {
        padding: 72px 32px;
      }

      .section-inner {
        max-width: 1000px;
        margin: 0 auto;
      }

      .section-label {
        font-family: var(--font-display);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--text-muted);
        margin-bottom: 36px;
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .section-label::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
      }

      /* —— Book cards —— */
      .book-grid {
        display: flex;
        flex-direction: column;
        gap: 14px;
      }

      .book-card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px 28px;
        display: flex;
        flex-direction: column;
        transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
        position: relative;
        overflow: hidden;
      }

      .book-card::before {
        content: "";
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--orange), transparent);
        opacity: 0;
        transition: opacity 0.25s ease;
      }

      .book-card:hover {
        transform: translateY(-3px);
        border-color: var(--border-hover);
        background: var(--panel-hover);
      }

      .book-card:hover::before { opacity: 1; }

      .book-card .tag {
        align-self: flex-start;
        font-family: var(--font-display);
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--orange);
        background: var(--orange-soft);
        padding: 5px 12px;
        border-radius: 999px;
        margin-bottom: 14px;
      }

      .book-card strong {
        font-family: var(--font-display);
        font-size: 19px;
        font-weight: 600;
        line-height: 1.25;
        letter-spacing: -0.01em;
        color: var(--white);
      }

      .book-card .description {
        margin-top: 10px;
        color: var(--text-muted);
        font-size: 14px;
        line-height: 1.55;
        flex: 1;
      }

      .book-card .go {
        margin-top: 24px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: var(--font-display);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--white);
      }

      .book-card .go svg {
        width: 16px; height: 16px;
        transition: transform 0.25s ease;
      }

      .book-card:hover .go svg { transform: translateX(4px); }
      .book-card:hover .go { color: var(--orange); }

      /* —— Blog posts —— */
      .post-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
      }

      .post-card {
        display: flex;
        flex-direction: column;
        padding: 24px 28px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--panel);
        transition: border-color 0.25s ease, background 0.25s ease, transform 0.25s ease;
      }

      .post-card:hover {
        transform: translateY(-2px);
        border-color: var(--border-hover);
        background: var(--panel-hover);
      }

      .post-card .tag {
        align-self: flex-start;
        font-family: var(--font-display);
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--orange);
        background: var(--orange-soft);
        padding: 5px 12px;
        border-radius: 999px;
        margin-bottom: 14px;
      }

      .post-card strong {
        font-family: var(--font-display);
        font-size: 19px;
        font-weight: 600;
        line-height: 1.25;
        letter-spacing: -0.01em;
        color: var(--white);
      }

      .post-card .description {
        margin-top: 10px;
        color: var(--text-muted);
        font-size: 14px;
        line-height: 1.55;
      }

      .post-card .date {
        margin-top: 14px;
        font-family: var(--font-display);
        font-size: 12px;
        color: var(--text-muted);
      }

      .post-card:hover strong { color: var(--orange); }

      /* —— Footer —— */
      footer {
        padding: 40px 32px;
        text-align: center;
        font-size: 13px;
        font-family: var(--font-display);
        color: var(--text-muted);
        border-top: 1px solid var(--border);
      }

      footer a { color: var(--footer-link); }
      footer a:hover { color: var(--orange); }

      /* —— 响应式 —— */
      @media (max-width: 640px) {
        .nav { padding: 14px 20px; }
        .nav .nav-links { gap: 16px; }
        .nav .nav-links a:not(.cta):not(.theme-toggle) { display: none; }
        .hero { padding: 130px 20px 72px; }
        .section { padding: 56px 20px; }
        .book-card { padding: 24px; min-height: auto; }
      }
    </style>
  </head>
  <body>
    <!-- 背景层 -->
    <div class="bg-grid"></div>
    <div class="bg-glow"></div>

    <div class="page">
      <!-- Nav -->
      <nav class="nav">
        <a href="/" class="brand">yuancaoyaohw</a>
        <div class="nav-links">
          <a href="#books">电子书</a>
          <a href="#posts">博客</a>
          <a href="#travel">旅游攻略</a>
          <button class="theme-toggle" aria-label="切换主题" title="切换深/浅色主题">
            <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
            <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
          <a href="https://github.com/yuancaoyaoHW" class="cta">GitHub</a>
        </div>
      </nav>

      <!-- Hero -->
      <section class="hero">
        <div class="hero-inner">
          <span class="eyebrow">Blog · Translations · Infrastructure</span>
          <h1>AI Blog &amp; <span class="accent">Infra</span></h1>
          <p class="lede">AI 推理引擎、底层基础设施，以及相关的技术翻译与笔记。以可长期维护的文档站形式发布。</p>
        </div>
      </section>

      <!-- Books -->
      <section class="section" id="books">
        <div class="section-inner">
          <p class="section-label">电子书</p>
          <div class="book-grid">
            {
              books.map((book) => (
                <a class="book-card" href={book.href}>
                  <span class="tag">{book.tag}</span>
                  <strong>{book.title}</strong>
                  <span class="description">{book.description}</span>
                  <span class="go">
                    打开
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
                  </span>
                </a>
              ))
            }
          </div>
        </div>
      </section>

      <!-- Blog Posts -->
      <section class="section" id="posts">
        <div class="section-inner">
          <p class="section-label">博客</p>
          <div class="post-list">
            {
              blogPosts.map((post) => (
                <a class="post-card" href={post.href}>
                  <span class="tag">{post.tag}</span>
                  <strong>{post.title}</strong>
                  <span class="description">{post.description}</span>
                  <span class="date">{post.date}</span>
                </a>
              ))
            }
          </div>
        </div>
      </section>

      <!-- Travel Guides -->
      <section class="section" id="travel">
        <div class="section-inner">
          <p class="section-label">旅游攻略</p>
          <div class="post-list">
            {
              travelGuides.map((guide) => (
                <a class="post-card" href={guide.href}>
                  <span class="tag">{guide.tag}</span>
                  <strong>{guide.title}</strong>
                  <span class="description">{guide.description}</span>
                  <span class="date">{guide.date}</span>
                </a>
              ))
            }
          </div>
        </div>
      </section>

      <!-- Footer -->
      <footer>
        <p>© {new Date().getFullYear()} yuancaoyaohw · 由 Astro 与 Starlight 驱动 · <a href="https://github.com/yuancaoyaoHW">GitHub</a></p>
      </footer>
    </div>

    <script is:inline>
      // 主题切换逻辑
      (function () {
        var btn = document.querySelector('.theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', function () {
          var current = document.documentElement.getAttribute('data-theme');
          var next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
        });
      })();
    </script>
  </body>
</html>
