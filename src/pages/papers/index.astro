---
const papers = [
  {
    date: '2026-07-24',
    href: '/papers/2026-07-24/',
    summary: '7 篇推荐:Windowed-MTP (NVIDIA, speculative decoding)、PolyQ (UC Irvine, CPU 量化)、BaseRT (Apple M5 推理引擎)、GradRAG (Bloomberg, 多 agent RAG)、CKKS 容错 (东北大学)、Opto-ViT-v2 (光子 PEFT)、Hydrodynamics on Cerebras WSE (LLNL)',
    stats: '7 推荐 · 3 频道 · 8 候选',
  },
];
---

<!doctype html>
<html lang="zh-CN" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <title>每日论文 - yuancaoyaohw</title>
  <meta name="description" content="每日 AI 论文推荐 — AI Infra / Algorithms / Architecture 三频道" />
  <style>
    :root {
      --font-display: "Bricolage Grotesque", Arial, sans-serif;
      --font-body: "Inter", system-ui, -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
      --radius: 10px;
    }
    [data-theme="dark"] {
      --black: #080D10; --bg-1: #0B1117; --bg-2: #0E141C;
      --panel: #131A24; --panel-hover: #18212E;
      --white: #FFFFFF; --orange: #FF7A00; --orange-soft: rgba(255, 122, 0, 0.12);
      --text: #E7ECF3; --text-muted: #7C8699;
      --border: #1E2733; --border-hover: #2A3744;
      --nav-bg: rgba(8, 13, 16, 0.72);
      --grid-line: rgba(255, 255, 255, 0.025);
      --glow-1: rgba(255, 122, 0, 0.12); --glow-2: rgba(255, 122, 0, 0.07);
    }
    [data-theme="light"] {
      --black: #FAFAF7; --bg-1: #F4F4EF; --bg-2: #EFEEE9;
      --panel: #FFFFFF; --panel-hover: #F8F8F3;
      --white: #1A1F26; --orange: #E8620F; --orange-soft: rgba(232, 98, 15, 0.10);
      --text: #2C3338; --text-muted: #6A737B;
      --border: #E2E3DD; --border-hover: #CFD0C8;
      --nav-bg: rgba(250, 250, 247, 0.74);
      --grid-line: rgba(0, 0, 0, 0.035);
      --glow-1: rgba(232, 98, 15, 0.08); --glow-2: rgba(232, 98, 15, 0.05);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--black); color: var(--text); font-family: var(--font-body); font-size: 16px; line-height: 1.7; -webkit-font-smoothing: antialiased; overflow-x: hidden; transition: background 0.3s, color 0.3s; }
    a { color: inherit; text-decoration: none; }
    .bg-glow { position: fixed; inset: 0; z-index: 0; pointer-events: none; background: radial-gradient(50% 40% at 85% 5%, var(--glow-1) 0%, transparent 60%), radial-gradient(35% 25% at 20% 35%, var(--glow-2) 0%, transparent 60%); }
    .bg-grid { position: fixed; inset: 0; z-index: 0; pointer-events: none; background-image: linear-gradient(var(--grid-line) 1px, transparent 1px), linear-gradient(90deg, var(--grid-line) 1px, transparent 1px); background-size: 56px 56px; mask-image: radial-gradient(ellipse 90% 70% at 50% 20%, black 20%, transparent 75%); -webkit-mask-image: radial-gradient(ellipse 90% 70% at 50% 20%, black 20%, transparent 75%); }
    .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); background: var(--nav-bg); border-bottom: 1px solid var(--border); color: var(--white); padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; font-family: var(--font-display); }
    .nav .brand { font-size: 17px; font-weight: 600; letter-spacing: -0.02em; color: var(--white); }
    .nav .nav-links { display: flex; gap: 28px; align-items: center; }
    .nav .nav-links a { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted); transition: color 0.2s; }
    .nav .nav-links a:hover { color: var(--white); }
    .nav .nav-links a.active { color: var(--orange); }
    .page { position: relative; z-index: 1; }
    .hero { padding: 140px 32px 60px; }
    .hero-inner { max-width: 900px; margin: 0 auto; }
    .hero .eyebrow { display: inline-block; font-family: var(--font-display); font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.14em; color: var(--orange); margin-bottom: 20px; }
    .hero h1 { font-family: var(--font-display); font-size: clamp(32px, 5vw, 56px); font-weight: 500; line-height: 1.15; letter-spacing: -0.03em; margin-bottom: 24px; color: var(--white); }
    .hero h1 .accent { color: var(--orange); }
    .hero .lede { max-width: 560px; font-size: 17px; line-height: 1.65; color: var(--text-muted); }
    .section { padding: 48px 32px; }
    .section-inner { max-width: 900px; margin: 0 auto; }
    .section-label { font-family: var(--font-display); font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.14em; color: var(--text-muted); margin-bottom: 28px; display: flex; align-items: center; gap: 12px; }
    .section-label::after { content: ""; flex: 1; height: 1px; background: var(--border); }
    .post-card { display: flex; flex-direction: column; padding: 24px 28px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--panel); transition: border-color 0.25s, background 0.25s, transform 0.25s; margin-bottom: 14px; }
    .post-card:hover { transform: translateY(-2px); border-color: var(--border-hover); background: var(--panel-hover); }
    .post-card .tag { align-self: flex-start; font-family: var(--font-display); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--orange); background: var(--orange-soft); padding: 5px 12px; border-radius: 999px; margin-bottom: 14px; }
    .post-card strong { font-family: var(--font-display); font-size: 19px; font-weight: 600; line-height: 1.25; letter-spacing: -0.01em; color: var(--white); }
    .post-card .description { margin-top: 10px; color: var(--text-muted); font-size: 14px; line-height: 1.55; }
    .post-card .date { margin-top: 14px; font-family: var(--font-display); font-size: 12px; color: var(--text-muted); }
    .post-card:hover strong { color: var(--orange); }
    footer { padding: 40px 32px; text-align: center; font-size: 13px; font-family: var(--font-display); color: var(--text-muted); border-top: 1px solid var(--border); }
    footer a { color: var(--orange); }
    @media (max-width: 640px) { .nav { padding: 14px 20px; } .nav .nav-links { gap: 16px; } .nav .nav-links a:not(.cta) { display: none; } .hero { padding: 110px 20px 48px; } .section { padding: 36px 20px; } .post-card { padding: 24px; } }
  </style>
</head>
<body>
  <div class="bg-grid"></div>
  <div class="bg-glow"></div>
  <div class="page">
    <nav class="nav">
      <a href="/" class="brand">yuancaoyaohw</a>
      <div class="nav-links">
        <a href="/">首页</a>
        <a href="/papers/" class="active">每日论文</a>
        <a href="/#posts">博客</a>
        <a href="/#travel">旅游攻略</a>
      </div>
    </nav>
    <section class="hero">
      <div class="hero-inner">
        <span class="eyebrow">Daily Papers</span>
        <h1>每日<span class="accent">论文</span>推荐</h1>
        <p class="lede">AI Infra / Algorithms / Architecture 三频道自动抓取与评审,每日精选 score≥4 的论文。</p>
      </div>
    </section>
    <section class="section">
      <div class="section-inner">
        <p class="section-label">归档</p>
        <div class="post-list">
          {papers.map((p) => (
            <a class="post-card" href={p.href}>
              <span class="tag">{p.stats}</span>
              <strong>{p.date}</strong>
              <span class="description">{p.summary}</span>
              <span class="date">{p.date}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
    <footer>
      <p>© {new Date().getFullYear()} yuancaoyaohw · 每日论文由 Hermes Agent + paper-recommendation 技能自动生成 · <a href="https://github.com/yuancaoyaoHW">GitHub</a></p>
    </footer>
  </div>
</body>
</html>
