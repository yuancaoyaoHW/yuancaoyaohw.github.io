<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>博客 - yuancaoyaohw</title>
    <meta name="description" content="yuancaoyaohw 的博客入口" />
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.6;
        background: #f7f8fa;
        color: #1a1a2e;
      }

      main {
        width: min(860px, calc(100% - 32px));
        margin: 0 auto;
        padding: 56px 0;
      }

      a {
        color: #2457d6;
        font-weight: 700;
        text-decoration: none;
      }

      .post-list {
        list-style: none;
        padding: 0;
        margin: 32px 0;
      }

      .post-card {
        background: #fff;
        border: 1px solid #e4e7eb;
        border-radius: 8px;
        padding: 24px 28px;
        margin-bottom: 16px;
        transition: box-shadow .15s, border-color .15s;
      }

      .post-card:hover {
        border-color: #76b900;
        box-shadow: 0 4px 16px rgba(0,0,0,0.08);
      }

      .post-card a {
        display: block;
      }

      .post-tag {
        display: inline-block;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #3f8500;
        background: #eef7e0;
        padding: 2px 8px;
        border-radius: 3px;
        margin-bottom: 8px;
      }

      .post-title {
        font-size: 18px;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0 0 6px;
        line-height: 1.4;
      }

      .post-desc {
        font-size: 14px;
        font-weight: 400;
        color: #6c757d;
        margin: 0;
        line-height: 1.5;
      }

      .post-date {
        font-size: 12px;
        color: #898989;
        font-family: ui-monospace, monospace;
        margin-top: 8px;
        display: block;
      }
    </style>
  </head>
